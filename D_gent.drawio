        <mxCell id="routing_agent" parent="zone2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8e0ff;strokeColor=#7b6fc0;fontStyle=1;fontSize=12;arcSize=10;" tooltip="An LLM-based agent that analyses the user&#39;s NL query and classifies which Data Product (business domain) is responsible for answering it. Uses semantic similarity and domain keyword matching. Only reached on a cache MISS." value="Product Routing Agent&lt;br&gt;(LLM-Powered Classifier)" vertex="1">
