          <mxGeometry height="55" width="180" x="140" y="45" as="geometry" />
        </mxCell>
        <mxCell id="nl_query" parent="zone1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=2;arcSize=8;" tooltip="The raw user query in plain English. Could reference any business domain — Fraud, Risk, Compliance, Data Quality, etc." value="Natural Language Query&#xa;e.g. &quot;Show fraud txns &gt; $10K in Q1&quot;" vertex="1">
