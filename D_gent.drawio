        <mxCell id="prompt_builder" parent="zone4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#2980b9;fontStyle=1;fontSize=11;arcSize=8;" tooltip="Assembles the full LLM prompt: (1) user NL query, (2) selected data product&#39;s DB/schema/table metadata, (3) table relationship graph, (4) few-shot SQL examples for that domain, (5) output format instructions. For DQ analytics queries, also includes DQ metric definitions and scoring context." value="📋 Prompt Builder&lt;br&gt;(Context Assembler)&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
