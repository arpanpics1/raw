        <mxCell id="zone_cache_check" parent="1" style="swimlane;startSize=30;fillColor=#fff8f0;strokeColor=#e67e22;fontStyle=1;fontSize=12;fontColor=#7d4000;horizontal=1;swimlaneLine=1;rounded=1;arcSize=4;" value="② Query Cache Check — Similar queries served instantly without LLM / SQL execution" vertex="1">
          <mxGeometry height="180" width="1480" x="80" y="250" as="geometry" />
        </mxCell>
        <mxCell id="cache_lookup" parent="zone_cache_check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde8c8;strokeColor=#e67e22;fontStyle=1;fontSize=12;arcSize=10;" tooltip="Before routing to the LLM pipeline, this agent checks the Query Result Cache for semantically similar past queries. Uses vector embedding comparison (cosine similarity) to find matches above a configurable threshold (e.g. 0.92 similarity). If a match is found, the cached result is returned directly to the user — no SQL generation or execution needed." value="🔍 Cache Lookup Agent&#xa;(Semantic Similarity Check)" vertex="1">
          <mxGeometry height="75" width="260" x="140" y="50" as="geometry" />
        </mxCell>
        <mxCell id="cache_hit" parent="zone_cache_check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;fontStyle=1;fontSize=11;arcSize=8;" tooltip="When a semantically similar query is found in the cache, the pre-computed result set is returned immediately to the user. The matched NL query, the SQL used, and the cached result are all surfaced for transparency. Cache hit avoids all LLM, Data Fusion, and federated execution costs." value="✅ Cache HIT&#xa;Return stored result&#xa;directly to user" vertex="1">
          <mxGeometry height="75" width="200" x="520" y="50" as="geometry" />
        </mxCell>
        <mxCell id="cache_miss" parent="zone_cache_check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde8e8;strokeColor=#c0392b;fontSize=11;arcSize=8;" tooltip="When no sufficiently similar query exists in the cache, the request proceeds through the full pipeline: routing agent → data product → LLM → Data Fusion → federated SQL. The result will be stored in the cache afterwards." value="❌ Cache MISS&#xa;Proceed to routing agent&#xa;&amp; full pipeline" vertex="1">
          <mxGeometry height="75" width="200" x="850" y="40" as="geometry" />
        </mxCell>
        <mxCell id="cache_threshold" parent="zone_cache_check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff0d8;strokeColor=#e67e22;fontSize=10;align=left;spacingLeft=8;arcSize=6;" tooltip="The similarity threshold determines how close a new query must be to a cached one before the cached result is reused. A threshold of 0.92 is conservative (near-exact semantic match). This can be tuned per data product — DQ analytics queries may use a lower threshold than fraud queries." value="Similarity threshold: configurable&#xa;Default: ≥ 0.92 cosine similarity&#xa;Model: text-embedding-ada / BGE" vertex="1">
          <mxGeometry height="75" width="280" x="1150" y="40" as="geometry" />
        </mxCell>
