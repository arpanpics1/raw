        <mxCell id="llm_engine" parent="zone4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#aed6f1;strokeColor=#1a6fa0;fontStyle=1;fontSize=12;arcSize=10;" tooltip="Core LLM model that receives the assembled prompt and generates a syntactically correct SQL query scoped to the identified data product&#39;s tables and schema." value="🧠 LLM Engine&#xa;(SQL Generator)" vertex="1">
