          <mxGeometry x="620" y="180" width="200" height="100" as="geometry" />
        </mxCell>

        <!-- Chunk messages -->
        <mxCell id="chunk1" value="Chunk 1/3&#xa;[msg-id | seq=1 | total=3 | data...]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="360" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="chunk2" value="Chunk 2/3&#xa;[msg-id | seq=2 | total=3 | data...]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="410" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="chunk3" value="Chunk 3/3&#xa;[msg-id | seq=3 | total=3 | data...]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="580" y="460" width="280" height="40" as="geometry" />
        </mxCell>

