          <mxGeometry x="60" y="440" width="240" height="100" as="geometry" />
        </mxCell>

        <!-- Note box -->
        <mxCell id="note1" value="⚠️ Consumer must handle:&#xa;• Out-of-order chunks&#xa;• Missing / duplicate chunks&#xa;• Reassembly timeout" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=top;spacingLeft=8;rounded=1;fontSize=11;" vertex="1" parent="1">
